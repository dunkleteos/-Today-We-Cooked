  dialogueText: {fileID: 1972204096}
  nextButton: {fileID: 1998330305}
  panelParent: {fileID: 1998330300}
  dialogueContent: Hey there, chef!|I just heard a famous food critic is heading
    your way.|You need to impress him, or say goodbye to your restaurant.|Luckily
    for you, I have the ultimate hamburger recipe that will blow his mind!|First,
    gather fresh lettuce and ripe tomatoes from the garden towers.|Next, visit the
    Cheesy Arena for the finest meat and chedar.|Once you have all the ingredients,
    return to the kitchen and cook the perfect burger.|Serve it to the critic and
    hope your restaurant survives!
  audioSource: {fileID: 1044130889}
  typingSound: {fileID: 8300000, guid: 56278c4e775449d4faac4ef2e31b8345, type: 3}
  typingSpeed: 0.05
  nextSceneName: Stage1
